#!/usr/bin/env python3
"""KB CLI entry point.

The Python package lives at the plugin-level `scripts/` directory. This
entrypoint is at `bin/kb`, which Claude Code prepends to PATH when the
plugin is enabled.
"""

import os
import sys

_bin_dir = os.path.dirname(os.path.realpath(__file__))
_plugin_root = os.path.dirname(_bin_dir)
sys.path.insert(0, os.path.join(_plugin_root, "scripts"))

from kb_registry.cli import main

sys.exit(main() or 0)
