#!/usr/bin/env python3
"""KB CLI entry point.

The Python package lives at the plugin-level `scripts/` directory. Agent-
facing skills/commands/agents reference this entrypoint as
`${CLAUDE_PLUGIN_ROOT}/bin/kb` (per Anthropic plugin guidance — every
intra-plugin path goes through CLAUDE_PLUGIN_ROOT, never PATH). Human users
can symlink this onto PATH for convenience (`ln -sf "${CLAUDE_PLUGIN_ROOT}/bin/kb" ~/.local/bin/kb`)
but the plugin itself does not rely on PATH injection.
"""

import os
import sys

_bin_dir = os.path.dirname(os.path.realpath(__file__))
_plugin_root = os.path.dirname(_bin_dir)
sys.path.insert(0, os.path.join(_plugin_root, "scripts"))

from kb_registry.cli import main

sys.exit(main() or 0)
