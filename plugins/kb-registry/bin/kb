#!/usr/bin/env python3
"""KB Registry CLI entry point.

The Python package lives under
  skills/kb-registry/scripts/kb_registry/
relative to the plugin root. This entrypoint is itself at
  bin/kb
which Claude Code prepends to PATH when the plugin is enabled.
"""

import os
import sys

_bin_dir = os.path.dirname(os.path.realpath(__file__))
_plugin_root = os.path.dirname(_bin_dir)
_package_parent = os.path.join(
    _plugin_root, "skills", "kb-registry", "scripts"
)
sys.path.insert(0, _package_parent)

from kb_registry.cli import main

sys.exit(main() or 0)
